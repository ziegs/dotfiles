# i3 config file (v4)
#
# Please see http://i3wm.org/docs/userguide.html for a complete reference!

set $mod Mod4

# Font for window titles. Will also be used by the bar unless a different font
# is used in the bar {} block below. ISO 10646 = Unicode
font pango:roboto 12

output * background /usr/share/backgrounds/sway/Sway_Wallpaper_Blue_1920x1080.png fill

# The font above is very space-efficient, that is, it looks good, sharp and
# clear in small sizes. However, if you need a lot of unicode glyphs or
# right-to-left text rendering, you should instead use pango for rendering and
# chose a FreeType font, such as:
# font pango:DejaVu Sans Mono 10

smart_borders no_gaps
smart_gaps on

default_border pixel 1
default_floating_border pixel 2
titlebar_border_thickness 1
gaps                top         10
gaps                bottom  0
gaps                left  5
gaps                right 5
gaps                inner   10

# Use Mouse+$mod to drag floating windows to their wanted position
floating_modifier $mod

# Automatically swap back
workspace_auto_back_and_forth yes

# start a terminal
bindsym $mod+Return exec kitty

# kill focused window
bindsym $mod+Shift+q kill

# start dmenu (a program launcher)
bindsym $mod+d exec rofi -show run -fuzzy
bindsym $mod+Shift+d exec rofi -show drun -modi drun
bindsym $mod+Tab exec rofi -show Workspace

# change focus
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

# move focused window
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

# split in horizontal orientation
bindsym $mod+Shift+v split h

# split in vertical orientation
bindsym $mod+v split v

# enter fullscreen mode for the focused container
bindsym $mod+f fullscreen

# change container layout (stacked, tabbed, toggle split)
bindsym $mod+s layout stacking
bindsym $mod+t layout tabbed
bindsym $mod+c layout toggle split

# toggle tiling / floating
bindsym $mod+Shift+space floating toggle

# change focus between tiling / floating windows
bindsym $mod+space focus mode_toggle

# focus the parent container
bindsym $mod+a focus parent

# focus the child container
bindsym $mod+z focus child

# switch to workspace
bindsym $mod+1 workspace 1: corp
bindsym $mod+2 workspace 2: www
bindsym $mod+3 workspace 3: dev
bindsym $mod+4 workspace 4
bindsym $mod+5 workspace 5
bindsym $mod+6 workspace 6
bindsym $mod+7 workspace 7
bindsym $mod+8 workspace 8
bindsym $mod+9 workspace 9
bindsym $mod+0 workspace 10

# move focused container to workspace
bindsym $mod+Shift+1 move container to workspace 1: corp
bindsym $mod+Shift+2 move container to workspace 2: www
bindsym $mod+Shift+3 move container to workspace 3: dev
bindsym $mod+Shift+4 move container to workspace 4
bindsym $mod+Shift+5 move container to workspace 5
bindsym $mod+Shift+6 move container to workspace 6
bindsym $mod+Shift+7 move container to workspace 7
bindsym $mod+Shift+8 move container to workspace 8
bindsym $mod+Shift+9 move container to workspace 9
bindsym $mod+Shift+0 move container to workspace 10

# reload the configuration file
bindsym $mod+Shift+c reload
# restart i3 inplace (preserves your layout/session, can be used to upgrade i3)
bindsym $mod+Shift+r restart
bindsym $mod+Shift+e exec "swaynag -t warning -m 'You pressed the exit shortcut. Do you really want to exit sway? This will end your session.' -b 'Yes, exit sway' 'swaymsg exit'"

# resize window (you can also use the mouse for that)
set $resize 2
mode "resize" {
        # These bindings trigger as soon as you enter the resize mode

        # Pressing left will shrink the window’s width.
        # Pressing right will grow the window’s width.
        # Pressing up will shrink the window’s height.
        # Pressing down will grow the window’s height.
        bindsym h resize shrink width $resize px or $resize ppt
        bindsym j resize grow height $resize px or $resize ppt
        bindsym k resize shrink height $resize px or $resize ppt
        bindsym l resize grow width $resize px or $resize ppt

        # same bindings, but for the Colemak so I don't have to think about it
        bindsym n resize grow height $resize px or $resize ppt
        bindsym e resize shrink height $resize px or $resize ppt
        bindsym i resize grow width $resize px or $resize ppt

        # back to normal: Enter or Escape
        bindsym Return mode "default"
        bindsym Escape mode "default"
}

bindsym $mod+r mode "resize"
bindsym $mod+mod1+r exec echo "" | dmenu -p "New name for this workspace" | xargs -r swaymsg rename workspace to

set $mode_system System (l) lock, (e) logout, (s) suspend, (h) hibernate, (r) reboot, (Shift+s) shutdown
set $i3exit ~/.i3/i3exit
mode "$mode_system" {
    bindsym l exec --no-startup-id $i3exit lock, mode "default"
    bindsym e exec --no-startup-id $i3exit logout, mode "default"
    bindsym s exec --no-startup-id $i3exit suspend, mode "default"
    bindsym h exec --no-startup-id $i3exit hibernate, mode "default"
    bindsym r exec --no-startup-id $i3exit reboot, mode "default"
    bindsym Shift+s exec --no-startup-id $i3exit shutdown, mode "default"

    # back to normal: Enter or Escape
    bindsym Return mode "default"
    bindsym Escape mode "default"
}
bindsym $mod+Pause mode "$mode_system"

set $laptop eDP-1
bindswitch --reload --locked lid:on output $laptop disable
bindswitch --reload --locked lid:off output $laptop enable
exec_always ~/.config/sway/reset-displays.sh

set $locker swaylock
bindsym $mod+F12 exec $locker
exec swayidle -w \
       timeout 300 '$locker' \
       timeout 600 'swaymsg "output * dpms off"' \
          resume 'swaymsg "output * dpms on"' \
       before-sleep '$locker' \
       lock '$locker'

# Fullscreen "passthrough" mode so that i3 works in CRD without rebinding
mode "passthrough" {
  bindsym $mod+Escape mode "default"
}
bindsym $mod+Escape mode "passthrough"

# Audio
bindsym --locked XF86AudioRaiseVolume exec ~/.i3/vol.sh up
bindsym --locked XF86AudioLowerVolume exec ~/.i3/vol.sh down
bindsym --locked XF86AudioMute exec pactl set-sink-mute @DEFAULT_SINK@ toggle
bindsym --locked XF86AudioMicMute exec pactl set-source-mute @DEFAULT_SOURCE@ toggle

bindsym --locked XF86AudioPlay exec playerctl play-pause
bindsym --locked XF86AudioNext exec playerctl next
bindsym --locked XF86AudioPrev exec playerctl previous

# Brightness
# Sreen brightness controls
bindsym --locked XF86MonBrightnessUp exec brightnessctl set 5%+
bindsym --locked XF86MonBrightnessDown exec brightnessctl set --min-value=1 5%-

# Screenshots
# Ctrl -> selection; Shift -> clipboard
# all monitors to file
bindsym --release Print exec grimshot save screen "~/Pictures/screenshot-$(date +%F_%T).png"
# selection to file
bindsym --release Control+Print exec grimshot save area "~/Pictures/screenshot-$(date +%F_%T).png"
# all monitors to clipboard
bindsym --release Shift+Print exec grimshot copy screen
# selection to clipboard
bindsym --release Control+Shift+Print exec grimshot copy area

# Display
bindsym XF86Display exec ~/.i3/monitor_layout.sh
bindsym Ctrl+XF86Display exec ~/.i3/rofi-xrandr
bindsym $mod+XF86Display exec arandr

exec sh -c "ssh-agent -s -a $SSH_AUTH_SOCK"
exec dbus-update-activation-environment --systemd WAYLAND_DISPLAY DISPLAY SWAYSOCK XDG_CURRENT_DESKTOP=sway XDG_SESSION_DESKTOP=sway
exec env XDG_CURRENT_DESKTOP=gnome /usr/share/goobuntu-indicator/goobuntu_indicator.py


# Start i3bar to display a workspace bar (plus the system information i3status
# finds out, if available)
bar swaybar_command waybar

# colors
client.focused          #268bd2 #268bd2 #fdf6e3 #2e9ef4
client.focused_inactive #93a1a1 #93a1a1 #fdf6e3 #2e9ef4
client.unfocused        #073642 #073642 #657b83 #657b83
client.urgent           #dc322f #dc322f #fdf6e3 #2e9ef4

# 1-character marks
bindsym $mod+m exec i3-input -F 'mark %s' -l 1 -P 'Mark: '
bindsym $mod+g exec i3-input -F '[con_mark="%s"] focus' -l 1 -P 'Goto: '

# general window configs
for_window [window_role="pop-up"] floating enable
for_window [window_role="bubble"] floating enable
for_window [window_role="task_dialog"] floating enable
for_window [window_role="Preferences"] floating enable
for_window [window_type="dialog"] floating enable
for_window [window_type="menu"] floating enable

# window-specific configs
for_window [title="Android Emulator"] floating enable # android emulator title
for_window [title="Emulator"] floating enable # android emulator tool window
for_window [class="jetbrains-studio" title="Android Virtual Device Manager"] floating enable
for_window [class="Google Android Emulator"] floating enable
for_window [class="Steam"] floating enable
for_window [class="Thunar" title="File Operation Progress"] floating enable
for_window [app_id="vlc"] floating enable
for_window [app_id="pavucontrol"] sticky enable; floating enable, move right 632, move down 336
for_window [app_id="galculator"] floating enable; sticky enable
for_window [app_id="termfloat"] floating enable; sticky enable;  move left 0, move top 0
for_window [class="openrct2"] floating enable
for_window [title="Event Tester"] floating enable
bindsym XF86Calculator [con_mark="calc"] exec galculator

# Chrome
for_window [class="Google-chrome" window_role="pop-up"] floating enable, border normal
for_window [title="Page.*Unresponsive"] floating enable
for_window [title="Confirm Permissions"] floating enable, border normal # permissions popup

# Chat
for_window [class="Google-chrome.*" instance="crx_mdpkiolbdkhdjpekfbkbmhigcaggjagi"] mark "chat", floating disable
bindsym XF86Mail [con_mark="chat"] focus
bindsym Shift+XF86Mail [con_mark="chat"] move workspace current focus

# Music player (YouTube Music)
for_window [app_id="chrome-cinhimbnkkaeohfgghhklpknlkffjgod-Profile_2"] mark "music", border none floating enable move scratchpad
bindsym $mod+Shift+m [con_mark="music"] scratchpad show
bindsym XF86Tools [con_mark="music"] scratchpad show
for_window [title="Task Manager - Google Chrome"] floating enable, border normal

for_window [title="Picture in picture"] floating enable
for_window [app_id="^chrome-.*"] shortcuts_inhibitor disable

bindsym $mod+minus scratchpad show
bindsym $mod+Shift+minus move scratchpad

exec dex --autostart --environment sway

exec mako
bindsym $mod+grave makoctl dismiss
bindsym $mod+shift+grave makoctl invoke

input "1:1:AT_Translated_Set_2_keyboard" {
  xkb_layout us
  xkb_options ctrl:nocaps,altwin:swap_lalt_lwin
}

input "type:touchpad" {
  natural_scroll enabled
  pointer_accel .75
  tap enabled
  tap_button_map lrm
}

input "2:10:TPPS/2_Elan_TrackPoint" {
  pointer_accel .90
}

include /etc/sway/config.d/*
